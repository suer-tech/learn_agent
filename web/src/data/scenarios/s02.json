{
  "version": "s02",
  "title": "Инструменты",
  "description": "Агент с инструментами read, write, edit и bash",
  "steps": [
    {
      "type": "user_message",
      "content": "Добавь функцию greet(name) в hello.py",
      "annotation": "Пользователь запрашивает изменение кода"
    },
    {
      "type": "assistant_text",
      "content": "Сначала прочитаю текущий файл.",
      "annotation": "Модель выбирает read_file вместо bash cat"
    },
    {
      "type": "tool_call",
      "content": "hello.py",
      "toolName": "read_file",
      "annotation": "Отдельный инструмент чтения обеспечивает более чистый доступ к файлу"
    },
    {
      "type": "tool_result",
      "content": "print(\"Hello, World!\")",
      "toolName": "read_file",
      "annotation": "Содержимое файла возвращено модели"
    },
    {
      "type": "tool_call",
      "content": "hello.py\n---\ndef greet(name):\n    print(f\"Hello, {name}!\")\n\ngreet(\"World\")",
      "toolName": "write_file",
      "annotation": "write_file заменяет всё содержимое файла"
    },
    {
      "type": "tool_result",
      "content": "File written successfully",
      "toolName": "write_file",
      "annotation": "Запись подтверждена"
    },
    {
      "type": "assistant_text",
      "content": "Я обновил hello.py: добавил функцию greet(name), которая принимает параметр name.",
      "annotation": "4 инструмента побеждают 1: у каждого инструмента ясное и узкое назначение"
    }
  ]
}
